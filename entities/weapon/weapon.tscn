[node name="Weapon" type="Node3D"]
script = ExtResource("1")
projectile_scene = ExtResource("2")

[node name="Cooldown" type="Timer" parent="."]
wait_time = 0.2
one_shot = true
autostart = false

[node name="Reload" type="Timer" parent="."]
wait_time = 1.2
one_shot = true
autostart = false

[node name="PistolViewModel" type="Node3D" parent="."]
position = Vector3(0.12, -0.12, -0.25)

[node name="SprintSway" type="Node3D" parent="PistolViewModel"]
script = ExtResource("7")
sprint_pose_pos = Vector3(0.08, -0.06, 0.02)
sprint_pose_rot = Vector3(-5.0, 3.0, -8.0)
sway_roll_deg = 4.0
sway_lateral_deg = 1.2
sway_vert_deg = 1.8
editor_description = "Sprint pose + sine sway layer — children inherit this offset; tweens write PistolViewModel above"

[node name="Pistol" parent="PistolViewModel/SprintSway" instance=ExtResource("3")]

[node name="Muzzle" type="Marker3D" parent="PistolViewModel/SprintSway"]
position = Vector3(0.0, 0.0, -0.3)

[node name="MuzzleFlash" type="OmniLight3D" parent="PistolViewModel/SprintSway/Muzzle"]
light_color = Color(1.0, 0.7, 0.3, 1.0)
light_energy = 4.0
omni_range = 1.2
visible = false
editor_description = "Muzzle flash pulse — driven by weapon.gd _flash_pulse(); off by default"

[node name="FireSfx" type="AudioStreamPlayer" parent="."]
stream = ExtResource("4")
bus = &"SFX"

[node name="EmptySfx" type="AudioStreamPlayer" parent="."]
stream = ExtResource("5")
bus = &"SFX"
editor_description = "Dry-click on empty trigger — played by weapon.gd on out_of_ammo"

[node name="ReloadSfx" type="AudioStreamPlayer" parent="."]
stream = ExtResource("6")
bus = &"SFX"
editor_description = "Mechanical clack at reload start — played by weapon.gd on start_reload"

[node name="VfxRouter" type="Node" parent="."]
script = ExtResource("8")
editor_description = "Thin router: weapon fired/vfx_impact signals -> one-shot VFX scenes."
