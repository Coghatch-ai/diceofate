{
  "permissions": {
    "allow": [
      "Read(**)",
      "Glob(**)",
      "Grep(**)",
      "Write(.claude/**)",
      "Edit(.claude/**)",
      "Write(library/**)",
      "Edit(library/**)",
      "Write(design/**)",
      "Edit(design/**)",
      "Write(docs/**)",
      "Edit(docs/**)",
      "Write(CLAUDE.md)",
      "Edit(CLAUDE.md)",
      "Write(levels/**)",
      "Edit(levels/**)",
      "Write(entities/**)",
      "Edit(entities/**)",
      "Write(resources/**)",
      "Edit(resources/**)",
      "Write(shaders/**)",
      "Edit(shaders/**)",
      "Write(tools/**)",
      "Edit(tools/**)",
      "Write(assets/**)",
      "Edit(assets/**)",
      "Write(main.gd)",
      "Edit(main.gd)",
      "Write(project.godot)",
      "Edit(project.godot)",
      "Bash(**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "command -v rtk >/dev/null 2>&1 && rtk hook claude || true"
          }
        ]
      }
    ]
  }
}
